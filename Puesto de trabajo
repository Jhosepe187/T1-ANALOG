


class PuestoDeTrabajo:
    def __init__(self, codigo = 0, descripcion = "", area_solicitante = "", plazas_requeridas = 0):
        self.codigo = codigo
        self.descripcion = descripcion
        self.area_solicitante = area_solicitante
        self.plazas_requeridas = plazas_requeridas
        
    
    def __str__(self):
        return f"{self.codigo} | {self.descripcion} | (S/{self.area_solicitante} | {self.plazas_requeridas})"
    
    def __repr__(self):
        return f"{self.codigo} | {self.descripcion} | (S/{self.area_solicitante} | {self.plazas_requeridas})"