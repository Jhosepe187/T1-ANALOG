class PuestoDeTrabajo:
    def __init__(self, codigo = 0, descripcion = "", area_solicitante = "", plazas_requeridas = 0, sueldo = 0):
        self.codigo = codigo
        self.descripcion = descripcion
        self.area_solicitante = area_solicitante
        self.plazas_requeridas = plazas_requeridas
        self.sueldo = sueldo
        
    
    def __str__(self):
        return f"{self.codigo} | {self.descripcion} | (S/{self.area_solicitante} | {self.plazas_requeridas})"
    
    def __repr__(self):
        return f"{self.codigo} | {self.descripcion} | (S/{self.area_solicitante} | {self.plazas_requeridas})"
    
def buscaPuesto(lst, zapa) -> bool:
    for z in lst:
        if z.codigo == zapa.codigo and z.descripcion == zapa.descripcion and z.area_solicitante == zapa.area_solicitante and z.plazas_requeridas == zapa.plazas_requeridas:
            return True
    return False

def buscarSueldo(lst):
    for i in range(1, len(lst)):
        aux = lst[i]
        j = i - 1

        while j >= 0 and lst[j].sueldo < aux.sueldo:
            lst[j+1] = lst[j]
            j -= 1

        lst[j+1] = aux
